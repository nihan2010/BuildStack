# BuildStack Environment Variables
# Copy this file to .env.local and fill in your values

# Optional: BuiltWith API key for enhanced detection
# BUILTWITH_API_KEY=

# Optional: Rate limiting (requests per minute per IP)
# RATE_LIMIT_PER_MINUTE=10

# Optional: Max scan timeout in ms (default: 15000)
# SCAN_TIMEOUT_MS=15000
